# =============================================================================
# Nexus environment configuration
# Copy to `.env` at the repo root. Every variable here is validated at boot by
# `@nexus/shared/env` (Zod). Missing/invalid values fail fast with a clear error.
# =============================================================================

# --- Core infra -------------------------------------------------------------
# Postgres connection string (pgvector extension required — see docker-compose).
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus?schema=public"

# Redis connection string (BullMQ queue + pub/sub for SSE).
REDIS_URL="redis://localhost:6379"

# --- Security ---------------------------------------------------------------
# AES-256-GCM key for OAuth token encryption. MUST be 32 bytes.
# Generate: `openssl rand -base64 32`  (base64) or `openssl rand -hex 32` (hex).
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_OR_HEX_KEY"

# Secret used to sign session JWTs (custom auth). Use a long random string.
# Generate: `openssl rand -base64 48`
AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# --- AI ---------------------------------------------------------------------
# Which LLM backs the agent runtime: "gemini" or "openai". Switch anytime.
AI_PROVIDER="gemini"

# Google Gemini API key (has a free tier). Get one at https://aistudio.google.com/apikey
# NOT required in demo mode or when AI_PROVIDER=openai.
GEMINI_API_KEY=""
# Model to use. Defaults to gemini-3.1-flash-lite (cheap, current). Each model
# has its own free-tier quota bucket on your API key — check
# https://ai.dev/rate-limit and pick whichever still has daily headroom.
GEMINI_MODEL="gemini-3.1-flash-lite"

# OpenAI API key. Required only when AI_PROVIDER=openai and not in demo mode.
OPENAI_API_KEY=""
# Model to use. Defaults to a cheap, JSON-mode-capable model; override freely.
OPENAI_MODEL="gpt-4.1-nano"

# --- Integrations (OAuth connectors) ----------------------------------------
# Slack app credentials (Basic Information → App Credentials). Only needed to
# connect Slack in real mode. Redirect URL to register in the Slack app:
#   ${NEXT_PUBLIC_APP_URL}/api/oauth/slack/callback
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Google OAuth app (one app backs Gmail + Google Calendar). In Google Cloud:
# enable the Gmail API + Google Calendar API, configure the OAuth consent screen
# (add yourself as a test user), and create an OAuth client ID (Web application)
# with authorized redirect URI:
#   ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Atlassian OAuth app (Jira). Create at developer.atlassian.com/console/myapps
# as an "OAuth 2.0 (3LO)" app, add the Jira platform REST API with scopes
# read:jira-work + write:jira-work + offline_access, and set the callback URL
# to:
#   ${NEXT_PUBLIC_APP_URL}/api/oauth/atlassian/callback
ATLASSIAN_CLIENT_ID=""
ATLASSIAN_CLIENT_SECRET=""

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo mode: when "true", NO real Gemini/OAuth calls are made — the agent
# runtime returns realistic mocked plans, tool results, approvals, and progress.
# Safe for public portfolio deployments (zero token/abuse risk).
NEXT_PUBLIC_IS_DEMO_MODE="true"

NODE_ENV="development"
